<Window x:Class="HostBuilderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Host Builder App" Height="200" Width="350">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock x:Name="GreetingText"
                   Text="Click the button to get a greeting."
                   FontSize="16"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15" />
        <Button Content="Get Greeting"
                Click="OnGetGreetingClick"
                Padding="10,5"
                HorizontalAlignment="Left" />
    </StackPanel>
</Window>
